# EvoClaw 环境变量配置
# 复制本文件为 .env 并填入实际值

# 默认 LLM 配置
EVOCLAW_DEFAULT_API_KEY=sk-your-api-key
EVOCLAW_DEFAULT_PROVIDER=openai
EVOCLAW_DEFAULT_MODEL=gpt-4o-mini
EVOCLAW_DEFAULT_BASE_URL=https://api.openai.com/v1

# Embedding 配置（可选，用于向量搜索）
EVOCLAW_EMBEDDING_API_KEY=
EVOCLAW_EMBEDDING_BASE_URL=
EVOCLAW_EMBEDDING_PROVIDER=

# 服务端口和 Token（可选，默认随机生成）
EVOCLAW_PORT=
EVOCLAW_TOKEN=
