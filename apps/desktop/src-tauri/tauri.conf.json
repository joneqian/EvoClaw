{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxc/json-schema/tauri.conf.json",
  "productName": "EvoClaw",
  "version": "0.1.0",
  "identifier": "com.evoclaw.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "EvoClaw",
        "width": 1200,
        "height": 800,
        "minWidth": 1200,
        "minHeight": 800,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:*; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "resources": [
      "../../../packages/core/dist/server.mjs",
      "../../../packages/core/dist/server.cjs",
      "../../../packages/core/dist/migrations/*",
      "../../../packages/core/dist/node_modules/better-sqlite3/lib/*",
      "../../../packages/core/dist/node_modules/better-sqlite3/lib/methods/*",
      "../../../packages/core/dist/node_modules/better-sqlite3/package.json",
      "../../../packages/core/dist/node_modules/better-sqlite3/build/Release/better_sqlite3.node"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
