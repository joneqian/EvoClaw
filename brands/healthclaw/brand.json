{
  "name": "HealthClaw",
  "identifier": "com.healthclaw.app",
  "abbreviation": "HC",
  "dataDir": ".healthclaw",
  "dbFilename": "healthclaw.db",
  "configFilename": "health_claw.json",
  "keychainService": "com.healthclaw",
  "eventPrefix": "healthclaw",
  "colors": {
    "primary": "#3B82F6",
    "primaryDark": "#1D4ED8",
    "gradient": ["#60A5FA", "#2563EB"]
  },
  "windowTitle": "HealthClaw",
  "release": {
    "macOS": {
      "signingIdentity": "${APPLE_SIGNING_IDENTITY_HEALTHCLAW}",
      "entitlements": "${APPLE_ENTITLEMENTS_HEALTHCLAW}",
      "minimumSystemVersion": "13.0"
    },
    "windows": {
      "certificateThumbprint": "${WINDOWS_CERT_THUMBPRINT_HEALTHCLAW}",
      "digestAlgorithm": "sha256"
    },
    "updater": {
      "endpoints": ["${UPDATER_ENDPOINT_HEALTHCLAW}"],
      "pubkey": "${TAURI_UPDATER_PUBKEY}"
    }
  },
  "defaultEnv": {
    "DEEP_HEALTH_AI_SERVER_URL": "http://localhost:9100/api",
    "DEEP_HEALTH_AI_AGENT_KEY": "claw-6c637a625e4715f71d54d7cffd0a07b4",
    "DEEP_HEALTH_AI_PROJECT_CODE": "",
    "DEEP_HEALTH_AI_COMPANY_CODE": "",
    "DEEP_HEALTH_AI_EMPLOYEE_CODE": ""
  },
  "defaultLanguage": "zh",
  "features": {
    "WEIXIN": true,
    "MCP": true,
    "SILK_VOICE": true,
    "WECOM": false,
    "FEISHU": false,
    "CACHED_MICROCOMPACT": false,
    "REACTIVE_COMPACT": false
  }
}
