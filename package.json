{
  "name": "evoclaw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3",
    "node": ">=22.12",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "brand:apply": "bun scripts/brand-apply.mjs",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "version:bump": "node scripts/version-bump.mjs",
    "version:check": "node scripts/version-check.mjs",
    "dev:core": "turbo run dev --filter=@evoclaw/core",
    "dev": "./scripts/dev.sh",
    "build": "bun scripts/brand-apply.mjs && turbo run build",
    "build:desktop": "bun scripts/brand-apply.mjs && turbo run build --filter=@evoclaw/desktop",
    "build:dmg": "./scripts/build-dmg.sh",
    "dev:evoclaw": "./scripts/dev.sh",
    "build:evoclaw": "bun scripts/brand-apply.mjs && turbo run build",
    "build:desktop:evoclaw": "bun scripts/brand-apply.mjs && turbo run build --filter=@evoclaw/desktop",
    "build:dmg:evoclaw": "./scripts/build-dmg.sh",
    "dev:healthclaw": "BRAND=healthclaw ./scripts/dev.sh",
    "build:healthclaw": "BRAND=healthclaw bun scripts/brand-apply.mjs && turbo run build",
    "build:desktop:healthclaw": "BRAND=healthclaw bun scripts/brand-apply.mjs && turbo run build --filter=@evoclaw/desktop",
    "build:dmg:healthclaw": "BRAND=healthclaw ./scripts/build-dmg.sh"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "oxlint": "^0.17.0",
    "sharp": "^0.34.5",
    "turbo": "^2.9.6",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  }
}
